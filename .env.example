# OneTap AI — environment configuration template
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Real environment variables override anything set here.

# --- Database (MariaDB) ---
# Defaults below match docker-compose.yml for local development.
DB_HOST=localhost
DB_PORT=3306
DB_USER=onetapai_user
DB_PASSWORD=onetapai_password
DB_NAME=onetapai

# --- Data source API (secret — required for ingestion) ---
# Henrik Dev Valorant API key: https://docs.henrikdev.xyz/
HENRIK_API_KEY=
# Official Riot API key (optional, only if using the Riot ingestion path)
RIOT_API_KEY=

# --- Embeddings (FastEmbed — local, no key needed) ---
# Model + dimension must match. Defaults are set in config.py; override only
# if you switch models (e.g. BAAI/bge-base-en-v1.5 -> EMBEDDING_DIM=768).
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_DIM=384
# Sparse BM25 model for hybrid retrieval (local, tiny):
# SPARSE_EMBEDDING_MODEL=Qdrant/bm25

# --- LLM generation (OpenRouter) ---
# Get a key at https://openrouter.ai/keys . Browse models (and ":free" ones)
# at https://openrouter.ai/models .
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Henrik API rate limiting (free tier ~30 req/min) ---
HENRIK_RPM=25
HENRIK_MAX_CONCURRENCY=4

# --- Ingestion backfill ---
BACKFILL_TARGET=1000
BACKFILL_SIZE=10

# --- Raw JSON archival (S3 / MinIO) ---
# Leave S3_ENDPOINT_URL blank to archive to local data/raw/ only.
# For the bundled MinIO (docker compose), use http://localhost:9000
S3_ENDPOINT_URL=
S3_BUCKET=onetapai-raw
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# --- Vector DB (Qdrant) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Cache / queue (Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- API server ---
# Comma-separated list of allowed CORS origins for the FastAPI gateway.
CORS_ORIGINS=http://localhost:3000

# Auth: JWT signing secret (REQUIRED — app refuses to start without it).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# Admin panel: comma-separated emails granted admin on startup. The accounts
# must already exist (register first, then add here and restart).
# ADMIN_EMAILS=you@example.com

# --- SMTP Email Verification (Optional — prints codes to console if unset) ---
# Brevo (recommended): dashboard -> SMTP & API -> SMTP tab.
# SMTP_USER is the Brevo SMTP *login* (e.g. 8xxxxxx001@smtp-brevo.com), NOT
# your sender address. SMTP_PASSWORD is the SMTP key (xsmtpsib-...), NOT your
# Brevo account password. SMTP_FROM must be a sender you verified in Brevo.
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=8xxxxxx001@smtp-brevo.com
# SMTP_PASSWORD=xsmtpsib-your-smtp-key
# SMTP_FROM=verify@onetapai.app
#
# Gmail alternative (dev): SMTP_HOST=smtp.gmail.com, SMTP_PORT=587,
# SMTP_USER=you@gmail.com, SMTP_PASSWORD=<app password>, SMTP_FROM=you@gmail.com
