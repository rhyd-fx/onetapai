
# --- Docker service credentials (compose reads these; dev fallbacks exist) ---
# Set strong values in any networked deployment. Ports bind to 127.0.0.1 by default.
MYSQL_ROOT_PASSWORD=
REDIS_PASSWORD=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Qdrant API key — if set here AND in the qdrant service, the client must send it.
QDRANT_API_KEY=
